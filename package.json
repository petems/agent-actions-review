{
  "name": "agent-actions-review",
  "version": "0.1.4",
  "description": "CLI and agent skills for diagnosing and fixing GitHub Actions CI/CD failures. Inspired by pbakaus/agent-reviews.",
  "license": "MIT",
  "author": "Peter Souter",
  "bin": {
    "agent-actions-review": "bin/agent-actions-review.js"
  },
  "main": "bin/agent-actions-review.js",
  "files": [
    "bin/",
    "lib/",
    "skills/",
    ".claude-plugin/"
  ],
  "scripts": {
    "install-skills": "node scripts/install-skills.js",
    "prepare": "npm run install-skills",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "github",
    "github-actions",
    "ci-cd",
    "claude-code",
    "ai-agent",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petems/agent-actions-review.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.4.2",
    "vitest": "^4.1.6"
  }
}
